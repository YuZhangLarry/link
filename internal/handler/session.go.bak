	if err != nil {
		c.JSON(http.StatusNotFound, gin.H{
			"code":    -1,
			"message": "会话不存在",
			"error":   err.Error(),
		})
		return
	}

	log.Printf("🔍 [GetSessionDetail] resp: %+v", resp)
	log.Printf("🔍 [GetSessionDetail] Session: %s, Messages: %d", resp.Session.ID, len(resp.Messages))

	c.JSON(http.StatusOK, gin.H{
